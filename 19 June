5. Missing number [LeetCode-268]->

class Solution {
    public int missingNumber(int[] nums) {
        int n=nums.length;
        int sum=0,actualSum;
        for(int i=0;i<n;i++)
        {
            sum=sum+nums[i];
        }
        actualSum=(n*(n+1))/2;
        return actualSum-sum;
    }
}

